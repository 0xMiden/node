{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "type": "stat",
      "title": "Spans / sec (all services)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "id": 100,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "fieldConfig": { "defaults": { "unit": "reqps", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 100 }, { "color": "red", "value": 1000 }] } } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(rate(traces_spanmetrics_calls_total[1m]))", "refId": "A" }]
    },
    {
      "type": "stat",
      "title": "Error rate (all services, 5m)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "id": 101,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.01 }, { "color": "red", "value": 0.05 }] } } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(rate(traces_spanmetrics_calls_total{status_code=\"STATUS_CODE_ERROR\"}[5m])) / clamp_min(sum(rate(traces_spanmetrics_calls_total[5m])), 1e-9)", "refId": "A" }]
    },
    {
      "type": "stat",
      "title": "Active services",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "id": 102,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none" },
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 3 }, { "color": "green", "value": 5 }] } } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "count(count by (service_name) (rate(traces_spanmetrics_calls_total[2m]) > 0))", "refId": "A" }]
    },
    {
      "type": "stat",
      "title": "Collector accepted spans/s",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "id": 103,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "fieldConfig": { "defaults": { "unit": "reqps", "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 0.01 }] } } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(rate(otelcol_receiver_accepted_spans_total[1m]))", "refId": "A" }]
    },

    {
      "type": "nodeGraph",
      "title": "Service Graph",
      "description": "Edges derived from CLIENT/SERVER span pairs. Populates after node restart with span-kind fix.",
      "datasource": { "type": "tempo", "uid": "tempo" },
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 4 },
      "id": 10,
      "targets": [{ "datasource": { "type": "tempo", "uid": "tempo" }, "queryType": "serviceMap", "refId": "A" }]
    },

    {
      "type": "timeseries",
      "title": "Throughput by service (calls/s)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "id": 11,
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 10, "stacking": { "mode": "normal" } } } },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum by (service_name) (rate(traces_spanmetrics_calls_total[1m]))", "legendFormat": "{{service_name}}", "refId": "A" }]
    },
    {
      "type": "timeseries",
      "title": "Error rate by service",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "id": 12,
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1, "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 10 } } },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum by (service_name) (rate(traces_spanmetrics_calls_total{status_code=\"STATUS_CODE_ERROR\"}[5m])) / clamp_min(sum by (service_name) (rate(traces_spanmetrics_calls_total[5m])), 1e-9)", "legendFormat": "{{service_name}}", "refId": "A" }]
    },

    {
      "type": "timeseries",
      "title": "Latency p50 by span",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 24 },
      "id": 13,
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 5 } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.50, sum by (le, span_name) (rate(traces_spanmetrics_latency_bucket[5m])))", "legendFormat": "{{span_name}}", "refId": "A" }]
    },
    {
      "type": "timeseries",
      "title": "Latency p95 by span",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 24 },
      "id": 14,
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 5 } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.95, sum by (le, span_name) (rate(traces_spanmetrics_latency_bucket[5m])))", "legendFormat": "{{span_name}}", "refId": "A" }]
    },
    {
      "type": "timeseries",
      "title": "Latency p99 by span",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 24 },
      "id": 15,
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 5 } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.99, sum by (le, span_name) (rate(traces_spanmetrics_latency_bucket[5m])))", "legendFormat": "{{span_name}}", "refId": "A" }]
    },

    {
      "type": "heatmap",
      "title": "Latency heatmap — block/batch builder + apply_block + validate_block (with exemplars)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 32 },
      "id": 16,
      "options": { "calculate": false, "yAxis": { "unit": "s" }, "exemplars": { "color": "rgba(255, 0, 255, 0.7)" } },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "sum by (le) (rate(traces_spanmetrics_latency_bucket{span_name=~\"block_builder.*|batch_builder.*|apply_block|validate_block|build_block|build_batch\"}[1m]))",
        "format": "heatmap",
        "legendFormat": "{{le}}",
        "exemplar": true,
        "refId": "A"
      }]
    },

    {
      "type": "table",
      "title": "Top 10 slow spans (p99, 5m)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 42 },
      "id": 17,
      "options": { "cellHeight": "sm", "showHeader": true, "sortBy": [{ "displayName": "p99", "desc": true }] },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "topk(10, histogram_quantile(0.99, sum by (le, service_name, span_name) (rate(traces_spanmetrics_latency_bucket[5m]))))",
        "format": "table",
        "instant": true,
        "refId": "A"
      }]
    },
    {
      "type": "bargauge",
      "title": "Spans/s by service (last 1m)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 42 },
      "id": 18,
      "options": { "orientation": "horizontal", "displayMode": "gradient", "valueMode": "color", "showUnfilled": true },
      "fieldConfig": { "defaults": { "unit": "reqps", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] } } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum by (service_name) (rate(traces_spanmetrics_calls_total[1m]))", "legendFormat": "{{service_name}}", "refId": "A" }]
    },

    {
      "type": "timeseries",
      "title": "RPC API methods — latency p95",
      "description": "Per-method latency for all gRPC endpoints across services.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 51 },
      "id": 19,
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 5 } } },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] } },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "histogram_quantile(0.95, sum by (le, span_name) (rate(traces_spanmetrics_latency_bucket{span_name=~\".*\\\\.Api/.*|.*\\\\.Rpc/.*\"}[5m])))",
        "legendFormat": "{{span_name}}",
        "refId": "A"
      }]
    },
    {
      "type": "timeseries",
      "title": "Store / DB operations — latency p95",
      "description": "Latency of store-side operations: apply_block, prove_block, save_proof, save_block, insert_*",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 51 },
      "id": 20,
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 5 } } },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] } },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "histogram_quantile(0.95, sum by (le, span_name) (rate(traces_spanmetrics_latency_bucket{service_name=\"miden-node-store\",span_name=~\"apply_block|prove_.*|save_.*|insert_.*|store\\\\..*|database\\\\..*\"}[5m])))",
        "legendFormat": "{{span_name}}",
        "refId": "A"
      }]
    },

    {
      "type": "timeseries",
      "title": "Network monitor — endpoint check rate",
      "description": "Rate of RPC / explorer / note-transport / prover health probes.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 59 },
      "id": 21,
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 10 } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "sum by (span_name) (rate(traces_spanmetrics_calls_total{service_name=\"miden-network-monitor\"}[1m]))",
        "legendFormat": "{{span_name}}",
        "refId": "A"
      }]
    },
    {
      "type": "timeseries",
      "title": "Collector pipeline — received vs sent + tail-sample drops",
      "description": "Tracks span ingestion at the collector, forwarding to Tempo, and tail-sampling drop rate.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 59 },
      "id": 22,
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 5 } } },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(rate(otelcol_receiver_accepted_spans_total[1m]))", "legendFormat": "accepted", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(rate(otelcol_exporter_sent_spans_total[1m]))", "legendFormat": "sent → tempo", "refId": "B" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(rate(otelcol_processor_tail_sampling_count_spans_sampled_total{sampled=\"false\"}[1m]))", "legendFormat": "dropped by tail-sampling", "refId": "C" }
      ]
    },

    {
      "type": "table",
      "title": "Recent Traces",
      "datasource": { "type": "tempo", "uid": "tempo" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 67 },
      "id": 1,
      "targets": [{ "datasource": { "type": "tempo", "uid": "tempo" }, "queryType": "traceqlSearch", "limit": 20, "tableType": "traces", "filters": [{ "id": "service-name", "tag": "service.name", "operator": "=", "scope": "resource" }], "refId": "A" }]
    },
    {
      "type": "table",
      "title": "Block Building Traces",
      "datasource": { "type": "tempo", "uid": "tempo" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 77 },
      "id": 2,
      "targets": [{ "datasource": { "type": "tempo", "uid": "tempo" }, "queryType": "traceql", "query": "{name =~ \"block_builder.*|build_block.*\"}", "limit": 20, "tableType": "traces", "refId": "A" }]
    },
    {
      "type": "table",
      "title": "Batch Building Traces",
      "datasource": { "type": "tempo", "uid": "tempo" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 87 },
      "id": 3,
      "targets": [{ "datasource": { "type": "tempo", "uid": "tempo" }, "queryType": "traceql", "query": "{name =~ \"batch_builder.*|build_batch.*\"}", "limit": 20, "tableType": "traces", "refId": "A" }]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["miden"],
  "templating": { "list": [] },
  "time": { "from": "now-30m", "to": "now" },
  "title": "Miden Node",
  "uid": "miden-node",
  "version": 4
}
